---

---

<header class="header">
  <nav class="nav">
    <a href="#hero" class="nav-brand">
      <svg
        class="logo-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="3"
      >
        <path d="M12 22c4-4 8-7.5 8-12a8 8 0 1 0-16 0c0 4.5 4 8 8 12z"></path>
        <path d="M12 12V8"></path>
        <path d="M12 8c0-2 1-4 3-4"></path>
      </svg>
      <span>PlantarIA</span>
    </a>
    <div class="nav-links">
      <a href="#funciones">Funciones</a>
      <a href="#beneficios">Beneficios</a>
      <a href="#ia">IA Asistente</a>
      <a href="#faq">FAQ</a>
    </div>

    <button id="menu-cell" class="menu">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="icon icon-tabler icons-tabler-filled icon-tabler-menu-2"
        ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
          d="M21 6a1 1 0 0 1 -1 1h-16a1 1 0 1 1 0 -2h16a1 1 0 0 1 1 1"
        ></path><path
          d="M21 12a1 1 0 0 1 -1 1h-16a1 1 0 0 1 0 -2h16a1 1 0 0 1 1 1"
        ></path><path
          d="M21 18a1 1 0 0 1 -1 1h-16a1 1 0 0 1 0 -2h16a1 1 0 0 1 1 1"
        ></path></svg
      >
    </button>
  </nav>
</header>

<style>
  .header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    background: rgba(13, 17, 23, 0.8);
    backdrop-filter: blur(7px);
    border-bottom: 1px solid transparent;
    border-image: linear-gradient(
        to right,
        transparent,
        var(--accent-green-light),
        transparent
      )
      1;
  }

  .nav {
    max-width: var(--maxwidth);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;

    .nav-brand {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-family: "Playfair Display", serif;
      font-size: 1.5rem;
      font-weight: bold;
      color: var(--text-primary);
      text-decoration: none;

      & > .logo-icon {
        width: 32px;
        height: 32px;
        color: var(--accent-green);
      }
    }

    .nav-links {
      display: flex;
      gap: 2rem;

      & > a {
        color: var(--text-secondary);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.3s ease;

        &:hover {
          color: var(--accent-green-light);
        }
      }

      @media (width <= 768px) {
        display: none;
      }
    }
  }
  .menu {
    background-color: transparent;
    color: var(--accent-green);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: none;
    padding: 0.4rem;
    border-radius: 0.3rem;
    transition: transform 0.07s ease;

    &:hover {
      background-color: var(--bg-card);
    }

    &:active {
      background-color: var(--bg-hover);
      transform: scale(0.9);
    }

    @media (width >= 768px) {
      display: none !important;
    }
  }
</style>
