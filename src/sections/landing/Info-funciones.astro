---
import infofunciones from "@/data/infofunciones.json";
---

<section id="funciones" class="features">
  <div class="container">
    <div class="section-header">
      <h2>Todo lo que necesitas saber</h2>
      <p>Herramientas diseñadas para cuidar mejor de tus plantas</p>
    </div>

    <div class="features-grid">
      {
        infofunciones.map((info) => (
          <article class="feature-card">
            <div class={`feature-icon ${info.color}`}>
              <svg>
                <use href={`/infofunciones.svg#${info.svg}`} />
              </svg>
            </div>
            <h3>{info.titulo}</h3>
            <p>{info.descrip}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  #funciones {
    padding-block: 3rem;
    background: linear-gradient(
      to bottom,
      var(--bg-secondary) 91%,
      transparent
    );

    .container {
      max-width: var(--maxwidth);
      margin: auto;

      & > .section-header {
        text-align: center;
        margin-bottom: 4rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      & > .features-grid {
        display: grid;
        margin-bottom: 2rem;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1rem;

        & > .feature-card {
          background-color: var(--bg-card);
          padding: 2.5rem;
          border-radius: 1rem;
          cursor: crosshair;

          &:hover {
            background-color: var(--bg-hover);
          }
        }
      }
    }
  }

  .feature-icon {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    margin-inline: auto;
  }

  .feature-icon svg {
    width: 32px;
    height: 32px;
  }

  .feature-icon.green {
    background: rgba(46, 160, 67, 0.15);
    color: var(--accent-green-light);
  }

  .feature-icon.teal {
    background: rgba(31, 111, 235, 0.15);
    color: var(--accent-teal);
  }

  .feature-icon.purple {
    background: rgba(163, 113, 247, 0.15);
    color: #a371f7;
  }

  .feature-icon.orange {
    background: rgba(219, 171, 13, 0.15);
    color: #dbab0d;
  }

  .feature-card h3 {
    margin-bottom: 0.75rem;
    font-family: "Inter", sans-serif;
  }
</style>
