---

---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <div class="nav-brand">
          <svg
            class="logo-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M12 22c4-4 8-7.5 8-12a8 8 0 1 0-16 0c0 4.5 4 8 8 12z"
            ></path>
            <path d="M12 12V8"></path>
            <path d="M12 8c0-2 1-4 3-4"></path>
          </svg>
          <span>PlantaCare</span>
        </div>
        <p>Tu compañero de confianza en el mundo del cultivo</p>
      </div>
      <div class="footer-links">
        <div class="footer-column">
          <h4>Navegación</h4>
          <a href="#funciones">Funciones</a>
          <a href="#beneficios">Beneficios</a>
          <a href="#ia">IA Asistente</a>
          <a href="#faq">FAQ</a>
        </div>
        <div class="footer-column">
          <h4>Contacto</h4>
          <span>info@plantacare.es</span>
          <span>Madrid, España</span>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2025 PlantaCare. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    padding: 4rem 0 2rem;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-bottom: 3rem;
  }

  .footer-brand p {
    margin-top: 1rem;
    font-size: 0.95rem;
  }

  .footer-links {
    display: flex;
    gap: 4rem;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-column h4 {
    font-family: "Inter", sans-serif;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .footer-column a,
  .footer-column span {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.3s ease;
  }

  .footer-column a:hover {
    color: var(--accent-green-light);
  }

  .footer-bottom {
    border-top: 1px solid var(--border-color);
    padding-top: 2rem;
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.875rem;
  }

  .footer > .logo-icon {
    width: 1rem !important;
  }
</style>
