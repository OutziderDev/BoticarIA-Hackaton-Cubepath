<script>
	function buscarPlanta() {
		const input = document.getElementById('plantSearch') as HTMLInputElement;
		const valor = input?.value?.trim();
		
		if (valor) {
			alert(`Buscando información sobre: ${valor}\n\nEsta功能 estará disponible pronto.`);
			console.log('Búsqueda:', valor);
		}
	}

	const input = document.getElementById('plantSearch');
	input?.addEventListener('keypress', (e) => {
		if (e.key === 'Enter') {
			buscarPlanta();
		}
	});
</script>
