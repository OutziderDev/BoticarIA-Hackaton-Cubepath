---

<Layout>
  <header class="header">
    <nav class="nav">
      <a href="/" class="nav-brand">
        <svg
          class="logo-icon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M12 22c4-4 8-7.5 8-12a8 8 0 1 0-16 0c0 4.5 4 8 8 12z"></path>
          <path d="M12 12V8"></path>
          <path d="M12 8c0-2 1-4 3-4"></path>
        </svg>
        <span>PlantaCare</span>
      </a>

      <div class="search-nav">
        <div class="search-box">
          <svg
            class="search-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
          <input
            type="text"
            id="plantSearch"
            placeholder="Buscar otra planta..."
            autocomplete="off"
            list="plantList"
          />
          <datalist id="plantList">
            {plantas.map((p) => <option value={p} />)}
          </datalist>
        </div>
      </div>

      <div class="nav-actions">
        <a href="/" class="btn-back">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M19 12H5"></path>
            <path d="M12 19l-7-7 7-7"></path>
          </svg>
          Volver
        </a>
      </div>
    </nav>
  </header>

  <main class="main-content">
    <div class="hero-plant">
      <div class="container">
        <div class="plant-header">
          <div class="plant-title">
            <h1>{planta.nombre}</h1>
            <p class="subtitle">{planta.subtitulo}</p>
          </div>
          <div class="difficulty-badge" data-level="facil">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
              <path d="M2 17l10 5 10-5"></path>
              <path d="M2 12l10 5 10-5"></path>
            </svg>
            <span>Fácil de cuidar</span>
          </div>
        </div>

        <div class="plant-showcase">
          <div class="plant-image">
            <img src={planta.imagen} alt={planta.nombre} />
            <div class="plant-tags">
              <span class="tag">Suculenta</span>
              <span class="tag">Medicinal</span>
              <span class="tag">Purificadora</span>
            </div>
          </div>

          <div class="plant-info">
            <h2>Información General</h2>
            <div class="info-grid">
              {
                fichaTecnica.map((item) => (
                  <div class="info-item">
                    <span class="info-label">{item.label}</span>
                    <span class="info-value">{item.value}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="content-grid">
      <div class="container">
        <div class="main-column">
          <section class="section care-section">
            <h2>
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M12 22c4-4 8-7.5 8-12a8 8 0 1 0-16 0c0 4.5 4 8 8 12z"
                ></path>
                <path d="M12 12v6"></path>
                <path d="M9 15h6"></path>
              </svg>
              Guía de Cuidados
            </h2>
            <div class="care-cards">
              {
                cuidados.map((item) => (
                  <div class="care-card">
                    <div class="care-header">
                      <span class="care-icon">{item.icono}</span>
                      <h3>{item.titulo}</h3>
                    </div>
                    <p class="care-desc">{item.descripcion}</p>
                    <div class="care-tip">
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <circle cx="12" cy="12" r="10" />
                        <path d="M12 16v-4" />
                        <path d="M12 8h.01" />
                      </svg>
                      <span>Consejo: {item.consejo}</span>
                    </div>
                  </div>
                ))
              }
            </div>
          </section>

          <section class="section pros-contras">
            <div class="pros">
              <h2>
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                  <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                Pros
              </h2>
              <ul>
                {prosContras.pros.map((item) => <li>{item}</li>)}
              </ul>
            </div>
            <div class="contras">
              <h2>
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <circle cx="12" cy="12" r="10"></circle>
                  <path d="M15 9l-6 6"></path>
                  <path d="M9 9l6 6"></path>
                </svg>
                Contras
              </h2>
              <ul>
                {prosContras.contras.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </section>
        </div>

        <aside class="sidebar">
          <section class="section companion-plants">
            <h2>
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                <path d="M2 17l10 5 10-5"></path>
                <path d="M2 12l10 5 10-5"></path>
              </svg>
              Plantas Aliadas
            </h2>
            <p class="section-desc">
              Plantas que conviven bien con el Aloe Vera
            </p>
            <div class="plants-list">
              {
                plantasAliadas.map((item) => (
                  <div class="plant-item ally">
                    <div class="plant-icon ally">
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                    </div>
                    <div class="plant-details">
                      <span class="plant-name">{item.nombre}</span>
                      <span class="plant-reason">{item.razon}</span>
                    </div>
                  </div>
                ))
              }
            </div>
          </section>

          <section class="section companion-plants bad">
            <h2>
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M15 9l-6 6"></path>
                <path d="M9 9l6 6"></path>
              </svg>
              Evitar Cerca
            </h2>
            <p class="section-desc">Plantas con necesidades incompatibles</p>
            <div class="plants-list">
              {
                plantasContraproducentes.map((item) => (
                  <div class="plant-item enemy">
                    <div class="plant-icon enemy">
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path d="M18 6L6 18" />
                        <path d="M6 6l12 12" />
                      </svg>
                    </div>
                    <div class="plant-details">
                      <span class="plant-name">{item.nombre}</span>
                      <span class="plant-reason">{item.razon}</span>
                    </div>
                  </div>
                ))
              }
            </div>
          </section>

          <div class="ai-card">
            <div class="ai-card-header">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2"
                ></path>
              </svg>
              <span>IA Contextual</span>
            </div>
            <p>
              ¿Tienes dudas específicas sobre el cuidado del Aloe Vera?
              Pregúntale a nuestro asistente.
            </p>
            <button class="btn-ai" onclick="abrirSidebarChat()">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path>
              </svg>
              Abrir Asistente
            </button>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <SidebarChat plantaNombre={planta.nombre} />

  <footer class="footer">
    <div class="container">
      <p>
        © 2025 PlantaCare. La información puede estar sujeta a errores. Consulta
        fuentes adicionales.
      </p>
    </div>
  </footer>
</Layout>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(13, 17, 23, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
  }

  .nav {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: "Playfair Display", serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon {
    width: 32px;
    height: 32px;
    color: var(--accent-green);
  }

  .search-nav {
    flex: 1;
    max-width: 400px;
  }

  .search-box {
    display: flex;
    align-items: center;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 50px;
    padding: 0.5rem 1rem;
    transition: all 0.3s ease;
  }

  .search-box:focus-within {
    border-color: var(--accent-green);
    box-shadow: 0 0 0 3px rgba(46, 160, 67, 0.15);
  }

  .search-icon {
    width: 18px;
    height: 18px;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .search-box input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 0.5rem;
    font-size: 0.95rem;
    color: var(--text-primary);
    outline: none;
  }

  .search-box input::placeholder {
    color: var(--text-muted);
  }

  .nav-actions {
    flex-shrink: 0;
  }

  .btn-back {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-sm);
    transition: all 0.3s ease;
  }

  .btn-back:hover {
    color: var(--text-primary);
    background: var(--bg-hover);
  }

  .btn-back svg {
    width: 18px;
    height: 18px;
  }

  .main-content {
    padding-top: 80px;
  }

  .hero-plant {
    background: linear-gradient(
      180deg,
      var(--bg-secondary) 0%,
      var(--bg-primary) 100%
    );
    padding: 3rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .plant-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
  }

  .plant-title h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    font-style: italic;
  }

  .difficulty-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(46, 160, 67, 0.15);
    color: var(--accent-green-light);
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .difficulty-badge svg {
    width: 18px;
    height: 18px;
  }

  .plant-showcase {
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: 3rem;
    align-items: start;
  }

  .plant-image {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-card);
  }

  .plant-image img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    display: block;
  }

  .plant-tags {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(4px);
    color: var(--text-primary);
    padding: 0.375rem 0.75rem;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .plant-info {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
